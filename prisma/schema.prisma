generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model USUARIOS {
  ID             Int        @id @default(autoincrement())
  CEDULA         String     @unique(map: "usuarios_CEDULA_key")
  NOMBRE         String
  APELLIDO       String
  CORREO         String     @unique(map: "usuarios_CORREO_key")
  HASH           String
  SALT           String
  ROL            ROL        @default(CONTADOR)
  ESTADO         Boolean    @default(true)
  FECHA_CREACION DateTime?  @default(now())
  FACTURAS       FACTURAS[]

  // --- MODULO CONTABLE ---
  empresaId         Int            @default(1)
  empresa           Empresa        @relation(fields: [empresaId], references: [id])
  asientosCreados   Asiento[]      @relation("AsientosCreados")
  asientosAprobados Asiento[]      @relation("AsientosAprobados")
  auditoriaLogs     AuditoriaLog[]

  @@map("usuarios")
}

model CLIENTES {
  ID               Int         @id @default(autoincrement())
  IDENTIFICACION   String      @unique(map: "clientes_IDENTIFICACION_key")
  RAZON_SOCIAL     String
  NOMBRE_COMERCIAL String?
  DIRECCION        String
  TELEFONO1        String
  TELEFONO2        String?
  CORREO           String?     @default("tiolucasoswaldo1967@gmail.com")
  TARIFA           String?
  GRUPO            String?
  ZONA             String?
  RUTA             String?
  VENDEDOR         String?
  COBRADOR         String?
  PROVINCIA        String?
  CIUDAD           String?
  PARROQUIA        String?
  FECHA_CREACION   DateTime?   @default(now())
  CUENTAS          CUENTAS[]
  FACTURAS         FACTURAS[]
  MEDIDORES        MEDIDORES[]

  @@map("clientes")
}

model CUENTAS {
  ID            Int       @id @default(autoincrement())
  FECHA_EMISION DateTime? @default(now())
  VALOR         Float?
  ESTADO        String?
  ID_CLIENTE    Int
  ABONOS        ABONOS[]
  cliente       CLIENTES  @relation(fields: [ID_CLIENTE], references: [ID])

  @@index([ID_CLIENTE], map: "CUENTAS_ID_CLIENTE_fkey")
  @@map("cuentas")
}

model ABONOS {
  ID          Int      @id @default(autoincrement())
  VALOR_ABONO Float
  FECHA_ABONO DateTime @default(now())
  CODIGO      String
  DESCRIPCION String
  ID_CUENTA   Int
  cuenta      CUENTAS  @relation(fields: [ID_CUENTA], references: [ID])

  // --- MODULO CONTABLE ---
  asientoId Int?
  asiento   Asiento? @relation(fields: [asientoId], references: [id])

  @@index([ID_CUENTA], map: "ABONOS_ID_CUENTA_fkey")
  @@map("abonos")
}

model MEDIDORES {
  ID               Int                @id @default(autoincrement())
  NUMERO_MEDIDOR   String             @unique(map: "medidores_NUMERO_MEDIDOR_key")
  MODELO           String?
  MARCA            String?
  UBICACION        String?
  FECHA_CREACION   DateTime?          @default(now())
  ID_CLIENTE       Int
  DETALLES_MEDIDOR DETALLES_MEDIDOR[]
  FACTURAS         FACTURAS[]
  cliente          CLIENTES           @relation(fields: [ID_CLIENTE], references: [ID])

  @@index([ID_CLIENTE], map: "MEDIDORES_ID_CLIENTE_fkey")
  @@map("medidores")
}

model DETALLES_MEDIDOR {
  ID            Int       @id @default(autoincrement())
  ID_MEDIDOR    Int
  FECHA_LECTURA DateTime  @default(now())
  LECTURA       String
  medidor       MEDIDORES @relation(fields: [ID_MEDIDOR], references: [ID])

  @@index([ID_MEDIDOR], map: "DETALLES_MEDIDOR_ID_MEDIDOR_fkey")
  @@map("detalles_medidor")
}

model SUCURSALES {
  ID            Int        @id @default(autoincrement())
  NOMBRE        String?
  UBICACION     String?
  PUNTO_EMISION String?
  FACTURAS      FACTURAS[]

  @@map("sucursales")
}

model RAZONES {
  ID               Int                @id @default(autoincrement())
  CODIGO           String?
  RAZON            String?
  PRECIO1          Decimal?           @db.Decimal(10, 2)
  PRECIO2          Decimal?           @db.Decimal(10, 2)
  IVA              Decimal?           @db.Decimal(5, 2)
  DETALLES_FACTURA DETALLES_FACTURA[]

  @@map("razones")
}

model FACTURAS {
  ID                 Int                @id @default(autoincrement())
  SECUENCIA          Int
  FECHA_EMISION      DateTime?          @default(now())
  FECHA_AUTORIZACION DateTime?
  ID_SUCURSAL        Int
  ID_USUARIO         Int
  ID_CLIENTE         Int
  ID_MEDIDOR         Int
  ESTADO_FACTURA     ESTADO_FACTURA?    @default(SIN_AUTORIZAR)
  TIPO_PAGO          TIPO_PAGO
  VALOR_SIN_IMPUESTO Float
  IVA                Float
  TOTAL              Float
  FECHA_VENCIMIENTO  DateTime?          @default(now())
  CLAVE_ACCESO       String?
  DETALLES_FACTURA   DETALLES_FACTURA[]
  cliente            CLIENTES           @relation(fields: [ID_CLIENTE], references: [ID])
  medidor            MEDIDORES          @relation(fields: [ID_MEDIDOR], references: [ID])
  sucursal           SUCURSALES         @relation(fields: [ID_SUCURSAL], references: [ID])
  usuario            USUARIOS           @relation(fields: [ID_USUARIO], references: [ID])

  // --- MODULO CONTABLE ---
  facturasAsiento FacturaAsiento[]

  @@index([ID_CLIENTE], map: "FACTURAS_ID_CLIENTE_fkey")
  @@index([ID_MEDIDOR], map: "FACTURAS_ID_MEDIDOR_fkey")
  @@index([ID_SUCURSAL], map: "FACTURAS_ID_SUCURSAL_fkey")
  @@index([ID_USUARIO], map: "FACTURAS_ID_USUARIO_fkey")
  @@map("facturas")
}

model DETALLES_FACTURA {
  ID          Int      @id @default(autoincrement())
  ID_FACTURA  Int
  ID_RAZON    Int
  DESCRIPCION String?
  SUBTOTAL    Float?
  DESCUENTO   Float?   @default(0)
  CANTIDAD    Int?     @default(1)
  PRECIO_IVA  Float?
  factura     FACTURAS @relation(fields: [ID_FACTURA], references: [ID])
  razon       RAZONES  @relation(fields: [ID_RAZON], references: [ID])

  @@index([ID_FACTURA], map: "DETALLES_FACTURA_ID_FACTURA_fkey")
  @@index([ID_RAZON], map: "DETALLES_FACTURA_ID_RAZON_fkey")
  @@map("detalles_factura")
}

model CONCEPTOS {
  ID             Int       @id @default(autoincrement())
  CODIGO         String    @unique(map: "CODIGO") @db.VarChar(32)
  COD_INTERNO    String?   @db.VarChar(32)
  DESCRIPCION    String    @db.VarChar(255)
  PRECIO_BASE    Decimal?  @db.Decimal(10, 2)
  REQUIERE_MES   Boolean   @default(false)
  ESTADO         Boolean   @default(true)
  FECHA_CREACION DateTime? @default(now()) @db.DateTime(0)

  @@map("conceptos")
}

model LiquidacionCompra {
  id                          Int    @id @default(autoincrement())
  fechaEmision                String
  dirEstablecimiento          String
  tipoIdentificacionProveedor String
  razonSocialProveedor        String
  identificacionProveedor     String
  totalSinImpuestos           Float
  totalDescuento              Float
  importeTotal                Float
  moneda                      String

  estab          String  @default("001") @db.VarChar(3)
  ptoEmi         String  @default("300") @db.VarChar(3)
  secuencial     Int     @default(0)
  emailProveedor String?

  xml       String?              @db.LongText
  accessKey String?              @unique
  estadoSri String?
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
  detalles  DetalleLiquidacion[]

  // AGREGAR ESTA RELACIÓN
  emisorId Int
  emisor   Emisor @relation(fields: [emisorId], references: [id], onDelete: Cascade)

  @@map("liquidacion_compra")
}

model DetalleLiquidacion {
  id                       Int               @id @default(autoincrement())
  codigoPrincipal          String
  descripcion              String
  precioUnitario           Float
  cantidad                 Float
  descuento                Float
  precioTotalSinImpuesto   Float
  codigoImpuesto           String
  codigoPorcentajeImpuesto String
  tarifaImpuesto           Float
  baseImponible            Float
  valorImpuesto            Float
  liquidacionId            Int
  liquidacion              LiquidacionCompra @relation(fields: [liquidacionId], references: [id])

  @@index([liquidacionId])
  @@map("detalle_liquidacion")
}

enum ROL {
  CONTADOR
  TESORERO
  ADMIN
}

enum ESTADO_FACTURA {
  AUTORIZADO
  ELIMINADO
  SIN_AUTORIZAR
  ANULADO
}

enum TIPO_PAGO {
  EFECTIVO
  CREDITO
  DEPOSITO
  CHEQUE
}

model Emisor {
  id                    Int      @id @default(autoincrement())
  ruc                   String   @unique
  razonSocial           String
  nombreComercial       String?
  dirMatriz             String
  estab                 String   @db.VarChar(3)
  ptoEmi                String   @db.VarChar(3)
  obligadoContabilidad  String   @default("SI")
  contribuyenteEspecial String?
  ambiente              String   @default("1")
  activo                Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  // AGREGAR ESTA RELACIÓN
  liquidacionesCompra LiquidacionCompra[]

  @@map("emisor")
}

model SecuencialDoc {
  id        Int      @id @default(autoincrement())
  codDoc    String   @db.VarChar(2) // '03'
  estab     String   @db.VarChar(3)
  ptoEmi    String   @db.VarChar(3)
  lastSeq   Int      @default(0)
  updatedAt DateTime @updatedAt

  @@unique([codDoc, estab, ptoEmi], name: "uniq_doc_serie")
  @@map("secuencial_doc")
}

// ============================================
// MODULO CONTABLE
// ============================================

enum EstadoPeriodo {
  ABIERTO
  CERRADO
}

enum EstadoAsiento {
  PENDIENTE
  APROBADO
}

model Empresa {
  id                 Int      @id @default(autoincrement())
  nombre             String
  email              String
  ruc                String   @unique
  direccion          String
  telefono           String
  moneda             String   @default("USD")
  representanteLegal String
  logo               String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  usuarios           USUARIOS[]
  periodosContables  PeriodoContable[]
  planesCuentas      PlanCuentas[]
  configAsientosAuto ConfigAsientoAuto[]

  @@map("empresas")
}

model PeriodoContable {
  id          Int           @id @default(autoincrement())
  nombre      String
  fechaInicio DateTime
  fechaFin    DateTime
  estado      EstadoPeriodo @default(ABIERTO)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  empresaId Int
  empresa   Empresa   @relation(fields: [empresaId], references: [id])
  asientos  Asiento[]

  @@unique([empresaId, nombre])
  @@map("periodos_contables")
}

model PlanCuentas {
  id         Int      @id @default(autoincrement())
  codigo     String
  nombre     String
  tipo       String
  naturaleza String
  casillero  String?
  nivel      Int
  esDetalle  Boolean
  activo     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  empresaId Int
  empresa   Empresa @relation(fields: [empresaId], references: [id])

  padreId Int?
  padre   PlanCuentas?  @relation("JerarquiaCuentas", fields: [padreId], references: [id], onDelete: Restrict)
  hijas   PlanCuentas[] @relation("JerarquiaCuentas")

  detallesAsiento DetalleAsiento[]

  configDebe  ConfigAsientoAuto[] @relation("CuentaDebe")
  configHaber ConfigAsientoAuto[] @relation("CuentaHaber")
  configIva   ConfigAsientoAuto[] @relation("CuentaIva")

  @@unique([empresaId, codigo])
  @@map("plan_cuentas")
}

model Asiento {
  id              Int           @id @default(autoincrement())
  comprobante     String?
  modelo          String?
  diarios         String?
  codigo          String?
  numero          Int
  fecha           DateTime
  nombre          String
  concepto        String
  estado          EstadoAsiento @default(PENDIENTE)
  formato         String?
  descuadre       Decimal       @default(0) @db.Decimal(10, 2)
  fechaAprobacion DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  periodoId Int
  periodo   PeriodoContable @relation(fields: [periodoId], references: [id])

  creadoPorId Int
  creadoPor   USUARIOS @relation("AsientosCreados", fields: [creadoPorId], references: [ID])

  aprobadoPorId Int?
  aprobadoPor   USUARIOS? @relation("AsientosAprobados", fields: [aprobadoPorId], references: [ID])

  detallesAsiento DetalleAsiento[]
  facturasAsiento FacturaAsiento[]
  abonos          ABONOS[]

  @@unique([periodoId, numero])
  @@map("asientos")
}

model DetalleAsiento {
  id         Int     @id @default(autoincrement())
  no         Int
  codcta     String
  nombre     String
  referencia String?
  descta     String?
  debe       Decimal @default(0) @db.Decimal(10, 2)
  haber      Decimal @default(0) @db.Decimal(10, 2)

  asientoId Int
  asiento   Asiento @relation(fields: [asientoId], references: [id])

  cuentaId Int
  cuenta   PlanCuentas @relation(fields: [cuentaId], references: [id])

  @@unique([asientoId, no])
  @@map("detalles_asiento")
}

model FacturaAsiento {
  id           Int      @id @default(autoincrement())
  tipoRelacion String
  createdAt    DateTime @default(now())

  facturaId Int
  factura   FACTURAS @relation(fields: [facturaId], references: [ID])

  asientoId Int
  asiento   Asiento @relation(fields: [asientoId], references: [id])

  @@unique([facturaId, asientoId])
  @@map("facturas_asiento")
}

model ConfigAsientoAuto {
  id              Int      @id @default(autoincrement())
  tipoTransaccion String
  activo          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  empresaId Int
  empresa   Empresa @relation(fields: [empresaId], references: [id])

  cuentaDebeId Int
  cuentaDebe   PlanCuentas @relation("CuentaDebe", fields: [cuentaDebeId], references: [id])

  cuentaHaberId Int
  cuentaHaber   PlanCuentas @relation("CuentaHaber", fields: [cuentaHaberId], references: [id])

  cuentaIvaId Int
  cuentaIva   PlanCuentas @relation("CuentaIva", fields: [cuentaIvaId], references: [id])

  @@unique([empresaId, tipoTransaccion])
  @@map("config_asientos_auto")
}

model AuditoriaLog {
  id           Int      @id @default(autoincrement())
  accion       String
  entidad      String
  entidadId    Int
  datosPrevios Json?
  datosNuevos  Json?
  ip           String?
  userAgent    String?
  createdAt    DateTime @default(now())

  usuarioId Int
  usuario   USUARIOS @relation(fields: [usuarioId], references: [ID])

  @@map("auditoria_logs")
}
